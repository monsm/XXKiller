#!name= AppleAIProxy
#!desc= Apple Intelligence 代理
#!author= monsm
[General]
name = Apple Intelligence & Siri (Proxy)
description = 将 Apple Intelligence、Siri 和私有云计算的请求通过 PROXY 规则路由。

[Rule]
# ===== Apple Intelligence 核心域名 =====
DOMAIN,appleintelligence.apple.com,Proxy
DOMAIN,appleintelligence2.apple.com,Proxy
DOMAIN,genai.apple.com,Proxy

# ===== Siri AI / 新版Siri独立App =====
DOMAIN,siri.apple.com,Proxy
DOMAIN,siri-api.apple.com,Proxy
DOMAIN,siri-intent.apple.com,Proxy
DOMAIN,siri-companion.apple.com,Proxy
DOMAIN,intelligence.apple.com,Proxy

# ===== Apple AI 云端模型（AFM） =====
DOMAIN,afm.apple.com,Proxy
DOMAIN,afm-api.apple.com,Proxy
DOMAIN,afm.cloud.apple.com,Proxy

# ===== Apple 官方 API =====
DOMAIN,api.apple.com,Proxy
DOMAIN,api2.apple.com,Proxy
DOMAIN,api5.apple.com,Proxy
DOMAIN,appleinc.akadns.net,Proxy
DOMAIN-SUFFIX,apple.com.akadns.net,Proxy

# ===== Gemini / Google大模型（Apple-Gemini合作后端） =====
DOMAIN,gemini.apple.com,Proxy
DOMAIN,geminiapis.apple.com,Proxy
DOMAIN,geminiprops.apple.com,Proxy
DOMAIN-SUFFIX,generativeai.google.com,Proxy
DOMAIN-SUFFIX,gemini.google.com,Proxy
DOMAIN-SUFFIX,ai.google.dev,Proxy
DOMAIN-SUFFIX,aiplatform.googleapis.com,Proxy

# ===== Private Relay / iCloud+ 中继 =====
DOMAIN-SUFFIX,smoot.apple.com,Proxy
DOMAIN-SUFFIX,apple-relay.apple.com,Proxy
DOMAIN-SUFFIX,apple-relay.cloudflare.com,Proxy
DOMAIN-SUFFIX,apple-relay.fastly-edge.com,Proxy
DOMAIN-SUFFIX,apple-relay.akamaized.net,Proxy
DOMAIN-SUFFIX,apple-relay.mask.apple-dns.net,Proxy
DOMAIN-SUFFIX,gateway.icloud.com,Proxy
DOMAIN-SUFFIX,cp4.cloudflare.com,Proxy
DOMAIN-SUFFIX,guzzoni.apple.com,Proxy
DOMAIN-SUFFIX,gspe1-ssl.ls.apple.com,Proxy

# ===== App Store 静态资源 =====
DOMAIN-SUFFIX,apps.mzstatic.com,Proxy

# ===== 关键字匹配（兜底新增子域名） =====
DOMAIN-KEYWORD,appleintelligence,Proxy
DOMAIN-KEYWORD,genai,Proxy
DOMAIN-KEYWORD,siri-ai,Proxy
DOMAIN-KEYWORD,siri_ai,Proxy
DOMAIN-KEYWORD,applellm,Proxy
DOMAIN-KEYWORD,apple-llm,Proxy
DOMAIN-KEYWORD,afm-cloud,Proxy

# ===== IP段兜底 =====
IP-CIDR,17.0.0.0/8,Proxy
IP-CIDR,142.250.0.0/15,Proxy
IP-CIDR,172.217.0.0/16,Proxy
IP-CIDR,216.58.192.0/19,Proxy
IP-CIDR,74.125.0.0/16,Proxy
